---
import { bio } from "../bio";

const { tabs } = bio;
const { active = '' } = Astro.props;
---

<nav class="tabs-nav" transition:name="tabs" transition:animate="none">
    {active && <a href="/" class="home-link" aria-label="Home"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></a>}
    {
        tabs.map((tab) => {
            const { url, name } = tab;
            const isActive = name === active;
            if (name === "Blogs") {
                return <a href="/blog" class:list={[{ active: isActive }]}>{name}</a>;
            }
            if (name === "Works") {
                return <a href="/works" class:list={[{ active: isActive }]}>{name}</a>;
            }
            return <a href={url} target="_blank" class:list={[{ active: isActive }]}>{name}</a>;
        })
    }
</nav>
<style>
    .tabs-nav {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0.35rem 0.35rem;
        gap: 0.5rem;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 100px;
        border: 1px solid var(--color-surface-border);
        width: fit-content;
    }

    .tabs-nav a {
        padding: 0.45rem 1.1rem;
        text-decoration: none;
        color: var(--color-dull);
        font-weight: 500;
        font-size: 0.95rem;
        border: 1.5px solid transparent;
        border-radius: 100px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        white-space: nowrap;
    }

    .tabs-nav .home-link {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.45rem 0.7rem;
    }

    .tabs-nav a:hover,
    .tabs-nav a.active {
        background: var(--nav-active-bg);
        border-color: var(--nav-active-border);
        box-shadow: var(--nav-active-shadow);
        color: var(--color-white);
    }

    @media screen and (max-width: 576px) {
        .tabs-nav {
            gap: 0.15rem;
            padding: 0.3rem;
        }
        .tabs-nav a {
            padding: 0.4rem 0.75rem;
            font-size: 0.85rem;
        }
    }
</style>
