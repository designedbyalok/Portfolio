---
import { bio } from "../bio";
const { socials } = bio;
---
<footer>
  <div class="footer-socials">
    {socials.filter(social => social.name !== "Peerlist").map((social) => (
      <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name}>
        <img src={social.icon} alt={social.alt} width="22" height="22" />
      </a>
    ))}
  </div>
</footer>
<style>
footer {
  padding: 1.5rem 1rem;
  margin-top: auto;
  width: 100%;
  display: flex;
  justify-content: center;
  flex-shrink: 0;
}
.footer-socials {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1.5rem;
}
.footer-socials a img {
  width: 22px;
  height: 22px;
  filter: var(--icon-invert);
  opacity: 0.5;
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.footer-socials a:hover img {
  transform: scale(1.15);
  opacity: 0.9;
}
</style>
