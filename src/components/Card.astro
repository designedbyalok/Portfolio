---
import { bio } from "../bio";

const { name, image, alt, designation, company, description } = bio;
---

<div class="profile-card">
	<div class="wrapper">
		<img alt={alt} src={image} width="200" height="200" />
		<div></div>
		<div></div>
		<div></div>
		<div></div>
	</div>
	<h2>Hi there, I am</h2>
	<h1>{name}</h1>
	<p>a {designation} at <a href="https://www.fold.health/" target="_blank" rel="noopener noreferrer">{company}</a>. {description}</p>
</div>
<style>
	.profile-card {
		padding: 1.5rem 1rem;
		cursor: default;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		width: 100%;
		max-width: 680px;
	}

	div.wrapper {
		position: relative;
		max-width: 100%;
		max-height: 100%;
		overflow: visible;
		z-index: -1;
	}

	.wrapper > div {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 100%;
		height: 100%;
		border: 2px solid var(--color-grey);
		border-radius: 50%;
		opacity: 0.15;
		animation: grow 4s ease infinite;
	}

	.wrapper > div:nth-of-type(1) { width: 150%; height: 150%; }
	.wrapper > div:nth-of-type(2) { width: 225%; height: 225%; animation-delay: 500ms; }
	.wrapper > div:nth-of-type(3) { width: 300%; height: 300%; animation-delay: 1000ms; }
	.wrapper > div:nth-of-type(4) { width: 375%; height: 375%; animation-delay: 1500ms; }

	@keyframes grow {
		0% { opacity: 0; transform: translate(-50%, -50%) scale(0.9); }
		40%, 50% { opacity: 0.25; transform: translate(-50%, -50%) scale(1); }
		100% { opacity: 0; }
	}

	img {
		width: 10rem;
		height: 10rem;
		border-radius: 50%;
		box-shadow: 10px 10px 100px 50px rgba(148, 148, 148, 0.15);
	}

	h2, h1 {
		text-align: center;
	}

	h1 {
		font-weight: 800;
		background: linear-gradient(261.26deg, #636363 3.96%, #ffffffc9 50.9%, #939393 97.85%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		background-size: 300% 300%;
		animation: pulse 4s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { background-position: 0% 0%; }
		50% { background-position: 100% 100%; }
	}

	h2 {
		font-weight: 500;
		color: var(--color-muted);
	}

	p {
		text-align: center;
		line-height: 1.7;
		max-width: 560px;
		color: var(--color-text);
	}

	a {
		font-weight: 600;
		color: #ffffff;
		text-decoration: none;
		transition: color 0.2s;
	}

	a:hover {
		color: #83b1fc;
		text-decoration: underline;
	}

	@media (max-width: 576px) {
		img {
			width: 5.5rem;
			height: 5.5rem;
		}
		.profile-card {
			padding: 0 1rem;
			gap: 0;
		}
		h1 {
			font-size: 2.25rem;
		}
		h2 {
			font-size: 0.95rem;
		}
		p {
			font-size: 0.8rem;
			padding: 0 0.5rem;
			line-height: 1.5;
		}
		.wrapper > div:nth-of-type(3),
		.wrapper > div:nth-of-type(4) {
			display: none;
		}
	}
</style>
