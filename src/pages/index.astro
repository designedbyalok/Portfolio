---
import Card from "../components/Card.astro";
import Tabs from "../components/Tabs.astro";
import Layout from "../layouts/Layout.astro";
import { bio } from "../bio";
---

<Layout title="Alok Kumar | Product Designer" bodyClass="home" hideFooter>
	<main>
		<div class="center-content" transition:name="hero" transition:animate="fade">
			<Card />
		</div>
		<div class="bottom-content">
			<Tabs />
			<div class="social-icons">
				{bio.socials.filter(social => social.name !== "Peerlist").map((social) => (
					<a href={social.url} target="_blank" rel="noopener noreferrer">
						<img src={social.icon} alt={social.alt} width="28" height="28" />
					</a>
				))}
			</div>
		</div>
	</main>
</Layout>

<style>
	main {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		min-height: 100dvh;
		width: 100%;
	}
	.center-content {
		flex: 1;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.bottom-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding-bottom: 1.25rem;
	}
	@media (max-width: 576px) {
		main {
			min-height: 100vh;
			min-height: 100dvh;
			justify-content: center;
			padding: 2rem 0 0;
		}
		.center-content {
			flex: none;
		}
		.bottom-content {
			gap: 0.75rem;
			padding: 1rem 0 1.5rem;
		}
		.social-icons {
			gap: 1.5rem;
		}
	}
	.social-icons {
		display: flex;
		gap: 2rem;
		justify-content: center;
		align-items: center;
	}
	.social-icons a img {
		width: 24px;
		height: 24px;
		filter: brightness(0) invert(1);
		transition: transform 0.2s ease, opacity 0.2s ease;
		opacity: 0.7;
	}
	.social-icons a:hover img {
		transform: scale(1.15);
		opacity: 1;
	}
</style>
