---
import Layout from "../layouts/Layout.astro";
import Tabs from "../components/Tabs.astro";
import { getBlogPosts } from '../lib/db';

const posts = await getBlogPosts();
---

<Layout title="Blog | Alok Kumar">
  <main class="blog-page">
    <div class="blog-top-nav">
      <Tabs active="Blogs" />
    </div>

    <div class="blog-container">
      <header class="blog-header">
        <h1>Blog</h1>
        <p class="subtitle">Thoughts on design, enterprise UX, and building better products</p>
      </header>

      <div class="search-bar" id="search-bar">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search posts..." id="search-input" autocomplete="off" />
        <button class="clear-btn" id="clear-btn" aria-label="Clear search">&times;</button>
      </div>

      <div class="blog-listing" id="blog-listing">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="blog-card" data-title={post.title.toLowerCase()} data-summary={post.summary.toLowerCase()} data-tags={post.tags.join(' ').toLowerCase()}>
            <div class="card-content">
              <div class="card-tags">
                {post.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h2>{post.title}</h2>
              <p>{post.summary}</p>
              <div class="card-meta">
                <span>{new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                {post.read_time && (
                  <>
                    <span class="dot">&middot;</span>
                    <span>{post.read_time}</span>
                  </>
                )}
              </div>
            </div>
            <div class="card-arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </div>
          </a>
        ))}
        <div class="no-results" id="no-results" style="display:none;">No posts found.</div>
      </div>
    </div>
  </main>

<script is:inline>
  function initSearch() {
    var input = document.getElementById('search-input');
    var clearBtn = document.getElementById('clear-btn');
    var listing = document.getElementById('blog-listing');
    var noResults = document.getElementById('no-results');
    var searchBar = document.getElementById('search-bar');

    if (!input || !clearBtn || !listing || !noResults || !searchBar) return;

    function filter() {
      var q = input.value.toLowerCase().trim();
      clearBtn.style.display = q ? 'flex' : 'none';
      searchBar.classList.toggle('has-value', !!q);

      var cards = listing.querySelectorAll('.blog-card');
      var visible = 0;
      cards.forEach(function(card) {
        var title = card.dataset.title || '';
        var summary = card.dataset.summary || '';
        var tags = card.dataset.tags || '';
        var match = !q || title.includes(q) || summary.includes(q) || tags.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    input.addEventListener('input', filter);
    clearBtn.addEventListener('click', function() {
      input.value = '';
      filter();
      input.focus();
    });

    input.addEventListener('focus', function() { searchBar.classList.add('focused'); });
    input.addEventListener('blur', function() { searchBar.classList.remove('focused'); });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
  document.addEventListener('astro:page-load', initSearch);
</script>
</Layout>

<style>
  .blog-page {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-top-nav {
    display: flex;
    justify-content: center;
    padding: 1.5rem 1rem 0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .blog-container {
    max-width: 720px;
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .blog-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-white);
    margin: 0 0 0.5rem;
  }

  .subtitle {
    color: var(--color-muted);
    font-size: 1rem;
    margin: 0;
    line-height: 1.6;
  }

  /* Search bar */
  .search-bar {
    display: flex;
    align-items: center;
    background: var(--color-surface);
    border-radius: 100px;
    padding: 0.55rem 1rem;
    margin-bottom: 2rem;
    border: 1.5px solid var(--color-surface-border);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--color-muted);
    gap: 0.6rem;
  }

  .search-bar.focused,
  .search-bar.has-value {
    background: var(--nav-active-bg);
    border-color: var(--nav-active-border);
    box-shadow: var(--nav-active-shadow);
    color: var(--color-white);
  }

  .search-bar svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .search-bar.focused svg,
  .search-bar.has-value svg {
    opacity: 1;
  }

  .search-bar input {
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-size: 0.95rem;
    font-family: inherit;
    width: 100%;
    padding: 0.15rem 0;
  }

  .search-bar input::placeholder {
    color: var(--color-dull);
  }

  .clear-btn {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--color-muted);
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0 0.2rem;
    line-height: 1;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .clear-btn:hover {
    color: var(--color-white);
  }

  /* Blog cards */
  .blog-listing {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .blog-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid transparent;
    background: transparent;
    text-decoration: none;
    color: inherit;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .blog-card:hover {
    background: var(--color-surface);
    border-color: var(--color-surface-border);
    box-shadow: var(--card-hover-shadow);
  }

  .blog-card:hover .card-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .tag {
    background: var(--tag-bg);
    color: var(--tag-color);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.65rem;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  .card-content h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 0.45rem;
    line-height: 1.4;
  }

  .card-content p {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin: 0 0 0.65rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-dull);
  }

  .dot {
    font-size: 0.6rem;
  }

  .card-arrow {
    flex-shrink: 0;
    opacity: 0;
    color: var(--color-muted);
    transition: opacity 0.3s ease, transform 0.3s ease;
    padding-top: 0.2rem;
  }

  .no-results {
    text-align: center;
    color: var(--color-muted);
    font-size: 1rem;
    padding: 3rem 0;
  }

  @media (max-width: 600px) {
    .blog-container {
      padding: 1.5rem 1rem 2rem;
    }
    .blog-header h1 {
      font-size: 1.75rem;
    }
    .card-content h2 {
      font-size: 1.05rem;
    }
    .blog-top-nav {
      padding-top: 1rem;
    }
  }
</style>
