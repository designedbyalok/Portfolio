---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('works');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, summary, image, tags, year, role, client } = project.data;
---

<Layout title={`${title} | Alok Kumar`}>
  <main class="project-page">
    <nav class="breadcrumb">
      <a href="/" class="crumb">Home</a>
      <span class="divider">/</span>
      <a href="/works" class="crumb">Works</a>
      <span class="divider">/</span>
      <span class="crumb current">{title}</span>
    </nav>

    <article class="project-article">
      <header class="project-header">
        <div class="header-tags">
          {tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
        <h1>{title}</h1>
        <p class="summary">{summary}</p>
        <div class="meta">
          {role && <span class="meta-item">{role}</span>}
          {client && (
            <>
              <span class="dot">&middot;</span>
              <span class="meta-item">{client}</span>
            </>
          )}
          <span class="dot">&middot;</span>
          <span class="meta-item">{year}</span>
        </div>
      </header>

      <div class="hero-image">
        <img src={image} alt={title} />
      </div>

      <div class="content">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .project-page {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1.25rem 3rem;
  }

  /* Breadcrumb — same pattern as blog detail */
  .breadcrumb {
    display: flex;
    align-items: center;
    background: rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 100px;
    padding: 0.4rem 0.6rem;
    font-size: 0.9rem;
    gap: 0.4rem;
    width: fit-content;
    border: 1px solid var(--color-surface-border);
    margin-bottom: 2.5rem;
    position: sticky;
    top: 1rem;
    z-index: 50;
  }

  .crumb {
    padding: 0.3rem 0.85rem;
    color: var(--color-muted);
    font-weight: 500;
    border: 1.5px solid transparent;
    border-radius: 100px;
    transition: all 0.3s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .crumb:hover:not(.current) {
    background: linear-gradient(
      123.29deg,
      rgba(81, 81, 81, 0.28) 23.34%,
      rgba(250, 250, 250, 0.18) 78.64%
    );
    border-color: rgba(175, 186, 199, 0.6);
    color: #fff;
  }

  .crumb.current {
    background: linear-gradient(
      123.29deg,
      rgba(81, 81, 81, 0.28) 23.34%,
      rgba(250, 250, 250, 0.18) 78.64%
    );
    border-color: rgba(175, 186, 199, 0.6);
    color: #fff;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .divider {
    color: var(--color-dull);
    font-size: 0.85rem;
    padding: 0 0.1rem;
  }

  /* Article */
  .project-article {
    max-width: 720px;
    width: 100%;
  }

  .project-header {
    margin-bottom: 2rem;
  }

  .header-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .tag {
    background: rgba(161, 77, 243, 0.12);
    color: #c49dff;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.65rem;
    border-radius: 100px;
  }

  .project-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .summary {
    font-size: 1.1rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-dull);
    font-size: 0.9rem;
  }

  .dot {
    font-size: 0.6rem;
  }

  /* Hero image */
  .hero-image {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  .hero-image img {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  /* Markdown content */
  .content {
    color: var(--color-text);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .content :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    margin: 2.5rem 0 0.75rem;
  }

  .content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
    margin: 1.75rem 0 0.5rem;
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
  }

  .content :global(ul), .content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .content :global(li) {
    margin-bottom: 0.4rem;
  }

  .content :global(strong) {
    color: #fff;
    font-weight: 600;
  }

  .content :global(a) {
    color: #c49dff;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .content :global(a:hover) {
    color: #d4b3ff;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--color-purple);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .content :global(code) {
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .content :global(img) {
    max-width: 100%;
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }

  @media (max-width: 600px) {
    .project-page {
      padding: 1rem 1rem 2rem;
    }
    .breadcrumb {
      font-size: 0.8rem;
      gap: 0.25rem;
      padding: 0.35rem 0.4rem;
    }
    .crumb {
      padding: 0.25rem 0.6rem;
    }
    .crumb.current {
      max-width: 130px;
    }
    .summary {
      font-size: 1rem;
    }
    .content {
      font-size: 1rem;
    }
    .hero-image {
      border-radius: 8px;
      margin-bottom: 2rem;
    }
  }
</style>
