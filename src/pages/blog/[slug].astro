---
import Layout from "../../layouts/Layout.astro";
import { getBlogPosts, getBlogPost } from '../../lib/db';
import { marked } from 'marked';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getBlogPost(slug!);
const { title, author, date, read_time, tags, content } = post;
const renderedContent = marked(content);
---

<Layout title={`${title} | Alok Kumar`}>
  <main class="article-page">
    <nav class="breadcrumb">
      <a href="/" class="crumb">Home</a>
      <span class="divider">/</span>
      <a href="/blog" class="crumb">Blog</a>
      <span class="divider">/</span>
      <span class="crumb current">{title}</span>
    </nav>

    <article class="blog-article">
      <header>
        <div class="article-tags">
          {tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
        <h1>{title}</h1>
        <div class="meta">
          <span>{author}</span>
          <span class="dot">&middot;</span>
          <span>{read_time}</span>
          <span class="dot">&middot;</span>
          <span>{new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
        </div>
      </header>

      <div class="content" set:html={renderedContent} />
    </article>
  </main>
</Layout>

<style>
  .article-page {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.5rem 1.25rem 3rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 100px;
    padding: 0.4rem 0.6rem;
    font-size: 0.9rem;
    gap: 0.4rem;
    width: fit-content;
    border: 1px solid var(--color-surface-border);
    margin-bottom: 2rem;
    position: sticky;
    top: 1rem;
    z-index: 50;
  }

  .crumb {
    padding: 0.3rem 0.85rem;
    color: var(--color-muted);
    font-weight: 500;
    border: 1.5px solid transparent;
    border-radius: 100px;
    transition: all 0.3s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .crumb:hover:not(.current) {
    background: var(--nav-active-bg);
    border-color: var(--nav-active-border);
    color: var(--color-white);
  }

  .crumb.current {
    background: var(--nav-active-bg);
    border-color: var(--nav-active-border);
    color: var(--color-white);
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .divider {
    color: var(--color-dull);
    font-size: 0.85rem;
    padding: 0 0.1rem;
  }

  .blog-article {
    max-width: 680px;
    width: 100%;
  }

  .blog-article header {
    margin-bottom: 2rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .tag {
    background: var(--tag-bg);
    color: var(--tag-color);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.65rem;
    border-radius: 100px;
  }

  .blog-article h1 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: var(--color-white);
    margin: 0 0 1rem;
    line-height: 1.25;
  }

  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .dot {
    font-size: 0.6rem;
  }

  .content {
    color: var(--color-text);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .content :global(p) {
    margin-bottom: 1.5rem;
  }

  .content :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 2rem 0 0.75rem;
  }

  .content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-white);
    margin: 1.5rem 0 0.5rem;
  }

  .content :global(a) {
    color: var(--link-color);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .content :global(a:hover) {
    color: var(--link-hover);
  }

  .content :global(ul), .content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.4rem;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--color-purple);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .content :global(code) {
    background: var(--code-bg);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .content :global(pre) {
    background: var(--pre-bg);
    padding: 1rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-surface-border);
  }

  .content :global(img) {
    max-width: 100%;
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }

  @media (max-width: 600px) {
    .article-page {
      padding: 1rem 1rem 2rem;
    }
    .breadcrumb {
      font-size: 0.8rem;
      gap: 0.25rem;
      padding: 0.35rem 0.4rem;
      max-width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .breadcrumb::-webkit-scrollbar {
      display: none;
    }
    .crumb {
      padding: 0.25rem 0.6rem;
    }
    .crumb.current {
      max-width: 150px;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .content {
      font-size: 1rem;
    }
    .content :global(pre) {
      font-size: 0.85rem;
    }
    .content :global(img) {
      border-radius: 0.5rem;
    }
  }
</style>
